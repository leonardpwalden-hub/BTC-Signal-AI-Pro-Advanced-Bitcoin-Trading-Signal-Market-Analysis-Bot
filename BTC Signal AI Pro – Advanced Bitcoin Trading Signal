def get_candles(interval):

    try:

        params = {

            "category": CATEGORY,

            "symbol": SYMBOL,

            "interval": interval,

            "limit": 500

        }

        res = requests.get(

            BASE_URL + "/v5/market/kline",

            params=params,

            timeout=10

        ).json()

        # ====================================================
        # 🔥 RESPONSE CHECK
        # ====================================================

        if not res.get("result"):

            return pd.DataFrame()

        lst = res["result"].get("list", [])

        if not lst:

            return pd.DataFrame()

        # ====================================================
        # 🔥 DATAFRAME SYSTEM
        # ====================================================

        df = pd.DataFrame(

            lst,

            columns=[

                "time",

                "open",

                "high",

                "low",

                "close",

                "volume",

                "turnover"

            ]

        )

        # ====================================================
        # 🔥 SORT SYSTEM
        # ====================================================

        df["time"] = df["time"].astype(float)

        df = df.sort_values("time")

        # ====================================================
        # 🔥 OHLC CONVERSION
        # ====================================================

        for c in [

            "open",

            "high",

            "low",

            "close",

            "volume"

        ]:

            df[c] = df[c].apply(safe_float)

        # ====================================================
        # 🔥 EMPTY CHECK
        # ====================================================

        if df.empty:

            return pd.DataFrame()

        # ====================================================
        # 🔥 FINAL DATA RETURN
        # ====================================================

        return df

    except:

        traceback.print_exc()

        return pd.DataFrame()


