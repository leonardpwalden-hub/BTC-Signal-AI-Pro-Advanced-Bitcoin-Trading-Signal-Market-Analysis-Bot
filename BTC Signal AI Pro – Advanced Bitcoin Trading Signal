def get_signal(df):

    try:

        # ====================================================
        # 🔥 BASIC DATA CHECK
        # ====================================================

        if df is None:

            return "NONE"

        if df.empty:

            return "NONE"

        df = df.copy().dropna()

        if len(df) < 30:

            return "NONE"

        # ====================================================
        # 🔥 EMA FILTER SYSTEM
        # ====================================================

        df["ema_fast"] = ta.trend.ema_indicator(

            close=df["close"],

            window=5

        )

        # ====================================================
        # 🔥 CURRENT MARKET DATA
        # ====================================================

        curr = df.iloc[-1]

        close = curr["close"]

        ema_fast = curr["ema_fast"]

        # ====================================================
        # 🔥 SUPPORT / RESISTANCE
        # ====================================================

        support = min(

            df["low"].tail(15)

        )

        resistance = max(

            df["high"].tail(15)

        )

        # ====================================================
        # 🔥 DISTANCE CHECK
        # ====================================================

        near_support = (

            close <= support * 1.001

        )

        near_resistance = (

            close >= resistance * 0.998

        )

        # ====================================================
        # 🔥 TREND FILTER
        # ====================================================

        bullish_filter = (

            close > ema_fast

        )

        bearish_filter = (

            close < ema_fast

        )

        # ====================================================
        # 🔥 FINAL BUY SIGNAL
        # ====================================================

        if (

            near_support

            and

            bullish_filter

        ):

            return "BUY"

        # ====================================================
        # 🔥 FINAL SELL SIGNAL
        # ====================================================

        if (

            near_resistance

            and

            bearish_filter

        ):

            return "SELL"

        # ====================================================
        # 🔥 NO SIGNAL
        # ====================================================

        return "NONE"

    except:

        traceback.print_exc()

        return "NONE"


