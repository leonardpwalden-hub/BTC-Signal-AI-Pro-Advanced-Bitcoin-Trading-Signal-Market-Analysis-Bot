def indicators(df):

    try:

        # ====================================================
        # 🔥 DATA VALIDATION
        # ====================================================

        if df is None:

            return pd.DataFrame()

        if df.empty:

            return df

        required_cols = [

            "high",

            "low",

            "close"

        ]

        for col in required_cols:

            if col not in df.columns:

                return df

        # ====================================================
        # 🔥 EMA SYSTEM
        # ====================================================

        df["ema_fast"] = df["close"].ewm(

            span=EMA_FAST

        ).mean()

        df["ema_slow"] = df["close"].ewm(

            span=EMA_SLOW

        ).mean()

        # ====================================================
        # 🔥 TRUE RANGE SYSTEM
        # ====================================================

        h1 = (

            df["high"]

            -

            df["low"]

        )

        hc = (

            df["high"]

            -

            df["close"].shift()

        ).abs()

        lc = (

            df["low"]

            -

            df["close"].shift()

        ).abs()

        tr = pd.concat(

            [

                h1,

                hc,

                lc

            ],

            axis=1

        ).max(axis=1)

        # ====================================================
        # 🔥 ATR SYSTEM
        # ====================================================

        df["atr"] = tr.rolling(

            ATR_PERIOD

        ).mean()

        # ====================================================
        # 🔥 EMA GAP SYSTEM
        # ====================================================

        df["ema_gap"] = (

            df["ema_fast"]

            -

            df["ema_slow"]

        ).abs()

        # ====================================================
        # 🔥 TREND SYSTEM
        # ====================================================

        df["trend"] = np.where(

            df["ema_fast"] >

            df["ema_slow"],

            "BULLISH",

            "BEARISH"

        )

        # ====================================================
        # 🔥 SIGNAL STRENGTH
        # ====================================================

        df["signal_power"] = np.where(

            df["ema_gap"] >= 80,

            "HIGH",

            np.where(

                df["ema_gap"] >= 40,

                "MEDIUM",

                "LOW"

            )

        )

        # ====================================================
        # 🔥 FINAL RETURN
        # ====================================================

        return df

    except:

        traceback.print_exc()

        return pd.DataFrame()


